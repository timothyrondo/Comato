# ── Comato x402 heartbeat server — environment ───────────────────────────────
# Copy to .env and fill in. NEVER commit real keys.
#
# NOTE: tuning params (port, facilitator URL, sync/relayer toggles, heartbeat
# cadence, payment ceiling) live in src/constants.ts (DEFAULTS) — adjust them
# there, not here. This file holds ONLY secrets + per-deployment values.
# ─────────────────────────────────────────────────────────────────────────────

# ── required ─────────────────────────────────────────────────────────────────
# Registered Comato EOA — the premium PAYEE. Must be the wallet allowlisted for the
# Celo leaderboard so Track 2 settlements (payee = wallet) attribute to Comato.
COMATO_WALLET=0x0000000000000000000000000000000000000000
# Celo facilitator API key, sent as X-API-Key on POST /settle (required — /settle 401s
# without it; 1 credit each, 500 free mainnet / 1000 testnet). Create it on the
# x402.celo.org dashboard (sign with the ops wallet, no gas). Format: x402_ + 48 hex.
X402_API_KEY=x402_your_facilitator_api_key

# ── optional (override) ──────────────────────────────────────────────────────
# Celo RPC used to read the settling tx sender for the relayer assertion (default forno).
CELO_RPC=https://forno.celo.org
# Premium charged per heartbeat, in USDC decimal (default 0.001 = 1000 atomic units).
PREMIUM_USDC=0.001

# --- risk-priced premiums (optional) ---
# Agent-written quote store; absent file = flat PREMIUM_USDC for everyone.
# QUOTE_STORE_PATH=../../.comato/quotes.json
