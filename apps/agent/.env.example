# ─────────────────────────────────────────────────────────────────────────────
# Comato agent — environment. Copy to .env and fill in. NEVER commit real keys.
# Safe defaults: DRY_RUN=true, and rescue/treasury/x402 are OFF until enabled.
#
# NOTE: tuning params (intervals, rescue/treasury/x402 knobs, chain id, addresses)
# live in src/defaults.ts — adjust them there, not here. This file holds ONLY
# secrets, per-deployment values, and operational toggles.
# ─────────────────────────────────────────────────────────────────────────────

# ── required ─────────────────────────────────────────────────────────────────
# ERC-8021 attribution code (assigned celo_… tag from Celo Builders). lowercase/
# digits/_, 1–32 chars. A made-up code tags txs but earns ZERO Track 1 credit.
ATTRIBUTION_CODE=celo_your_assigned_tag
# Subscribers to protect (JSON array). Per entry: address (required), hfThreshold
# (WAD string, def 1.05), debtAsset (def USDC), collateralAsset, policyId, premiumPaidUntilMs.
SUBSCRIBERS=[{"address":"0xYourSubscriber","hfThreshold":"1.05","debtAsset":"0xcebA9300f2b948710d2653dD7B07f33A8B32118C","premiumPaidUntilMs":9999999999999}]
# COMATO_WALLET private key (0x + 64 hex). Omit → READ-ONLY (monitor only, DRY_RUN forced).
# COMATO_PRIVATE_KEY=0x<64-hex-chars>

# ── operational toggles ──────────────────────────────────────────────────────
# When true (default), NOTHING is broadcast — calldata is built + logged only.
DRY_RUN=true
# Enable EOA-direct repay rescues (Track 1 via C1). Needs a funded key + DRY_RUN=false.
RESCUE_ENABLED=false
# Enable the treasury round-trip swap volume engine (Track 1 via C1).
TREASURY_ENABLED=false
# Enable the x402 paid-data client (Track 2 via C2/C3). Defaults on iff X402_DATA_URL is set.
X402_ENABLED=false

# ── optional (override) ──────────────────────────────────────────────────────
# Celo RPC (default https://forno.celo.org).
CELO_RPC=https://forno.celo.org
# Log verbosity: debug | info | warn | error (default info).
LOG_LEVEL=info
# Priced data endpoint the agent buys risk/price data from (must settle via the Celo facilitator).
# X402_DATA_URL=https://your-priced-data-endpoint/price
# ComatoExecutor address — required only if the executor safety path is enabled (see src/defaults.ts).
# EXECUTOR_ADDRESS=0x...
# ComatoPolicy registry address (optional).
# POLICY_ADDRESS=0x...

# --- AI underwriter (slow-loop pricer, arch §0) — optional ---
# Off by default; the agent bills the flat premium without it.
PRICER_ENABLED=false
# OpenAI-compatible gateway (DGRID). Required only when PRICER_ENABLED=true.
DGRID_API_KEY=
DGRID_BASE_URL=https://api.dgrid.ai/v1
# Model override (default openai/gpt-5-mini — reasoning-capable, ~6-9s/quote)
# DGRID_MODEL=
# Quote store shared with apps/server (../../ = repo root when run via bun scripts)
# QUOTE_STORE_PATH=../../.comato/quotes.json
