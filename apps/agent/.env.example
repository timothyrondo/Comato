# ─────────────────────────────────────────────────────────────────────────────
# Comato agent — environment. Copy to .env and fill in. NEVER commit real keys.
# Safe defaults: DRY_RUN=true, and rescue/treasury/x402 are OFF until configured.
# ─────────────────────────────────────────────────────────────────────────────

# ── Identity / chain ────────────────────────────────────────────────────────
# ERC-8021 attribution code from Celo Builders registration. lowercase/digits/_,
# 1–32 chars. Appended to EVERY EOA-direct tx so Track 1 (C1) attributes to us.
ATTRIBUTION_CODE=timo_comato

# Celo RPC (defaults to https://forno.celo.org).
CELO_RPC=https://forno.celo.org
CHAIN_ID=42220

# COMATO_WALLET private key (the single registered EOA = tx_from for all counts).
# Omit to run READ-ONLY (monitor only; DRY_RUN forced). 0x-prefixed 32-byte hex.
# COMATO_PRIVATE_KEY=0x<64-hex-chars>

# When true (default), NOTHING is broadcast — calldata is built + logged only.
# Set false ONLY with a funded key to send real txs.
DRY_RUN=true

LOG_LEVEL=info        # debug | info | warn | error

# ── Monitor ──────────────────────────────────────────────────────────────────
MONITOR_INTERVAL_MS=30000

# Subscribers to protect. JSON array. Per entry:
#   address            (required) the borrower's Aave account
#   hfThreshold        WAD-decimal string; rescue considered when HF < this (def "1.05")
#   debtAsset          asset a rescue repays; MUST be the actual variable-debt asset (def USDC)
#   collateralAsset    informational
#   policyId           on-chain policy id (only for the ComatoExecutor safety path)
#   premiumPaidUntilMs epoch-ms the subscriber is paid through (premium eligibility gate)
SUBSCRIBERS=[{"address":"0xYourSubscriber","hfThreshold":"1.05","debtAsset":"0xcebA9300f2b948710d2653dD7B07f33A8B32118C","premiumPaidUntilMs":9999999999999}]

# ── Rescue (EOA-direct repay, tagged → Track 1 via C1) ───────────────────────
RESCUE_ENABLED=false
RESCUE_DISTRESS_HF=1.05        # absolute genuine-distress ceiling (WAD-decimal). Rescue only if HF < this too.
RESCUE_MAX_AMOUNT=50           # max debt-asset units repaid per rescue (human decimal)
RESCUE_ASSET_DECIMALS=6        # decimals of the rescue debt asset (USDC/USDT = 6)
RESCUE_COOLDOWN_MS=3600000     # per-subscriber cooldown between rescues (rate limit)
RESCUE_MAX_PER_WINDOW=3        # max rescues per subscriber within the window
RESCUE_WINDOW_MS=86400000
RESCUE_REQUIRE_PREMIUM=true    # fail-closed: never rescue an unfunded policy
# Where the rate limiter persists per-subscriber cooldown/window state (O3). Loaded on
# startup so a crash/restart during the 6-day run does NOT clear cooldowns and re-open
# the float to draining. Set to "" to disable persistence (in-memory only). Gitignored.
RESCUE_STATE_FILE=.comato/rate-limiter-state.json
# Safety path (atomic, but does NOT earn Track 1 — its legs are contract-internal):
RESCUE_VIA_EXECUTOR=false
# EXECUTOR_ADDRESS=0x...        # required if RESCUE_VIA_EXECUTOR=true
# POLICY_ADDRESS=0x...          # ComatoPolicy registry (optional)

# ── Treasury (EOA-direct tagged swaps → Track 1 volume engine via C1) ─────────
TREASURY_ENABLED=false
TREASURY_INTERVAL_MS=60000
TREASURY_TOKEN_A=0xcebA9300f2b948710d2653dD7B07f33A8B32118C   # USDC (6 dec)
TREASURY_TOKEN_B=0x48065fbBE25f71C9282ddf5e1cD6D6A887483D5e   # USDT (6 dec)
TREASURY_TOKEN_A_DECIMALS=6
TREASURY_TOKEN_B_DECIMALS=6
TREASURY_SWAP_AMOUNT=1          # input per swap, in token A units (human decimal)
TREASURY_POOL_FEE=100          # Uniswap V3 fee tier (100 = 0.01%). Verify the live pool's tier.
TREASURY_SLIPPAGE_BPS=50       # amountOutMinimum tolerance (bps)
TREASURY_ROUND_TRIP=true       # A→B then B→A each cycle (keeps the fund whole)
TREASURY_MIN_RESERVE=0         # skip a swap if source balance would fall below this (token A units)
# TREASURY_ROUTER=0x5615CDAb10dc425a742d643d949a7F474C01abc4  # SwapRouter02 (default)

# ── x402 client (pay per data query → Track 2 payer side via C2, + C3) ────────
# NOTE: the x402 facilitator is chosen by the RESOURCE SERVER, not the client.
# For the payer-side count to register, X402_DATA_URL must settle through the
# Celo facilitator (https://x402.celo.org, relayer 0x0d74…FB48). The agent
# verifies each settlement's relayer on-chain and warns on a mismatch.
X402_ENABLED=false
# X402_DATA_URL=https://your-priced-data-endpoint/price
# THIRDWEB_CLIENT_ID=your_thirdweb_client_id      # or THIRDWEB_SECRET_KEY (server-side)
# THIRDWEB_SECRET_KEY=your_thirdweb_secret_key
X402_MAX_VALUE=100000          # max payment per request in base units (e.g. 100000 = 0.10 USDC @ 6dec)
X402_FACILITATOR_URL=https://x402.celo.org
