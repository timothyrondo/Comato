{
  "name": "comato",
  "private": true,
  "version": "0.0.0",
  "description": "Comato — gasless liquidation-rescue insurance on Celo",
  "packageManager": "bun@1.3.9",
  "workspaces": [
    "apps/*",
    "packages/shared",
    "e2e"
  ],
  "scripts": {
    "contracts:build": "cd packages/contracts && forge build",
    "contracts:test": "cd packages/contracts && forge test -vvv",
    "contracts:fmt": "cd packages/contracts && forge fmt",
    "anvil:celo": "anvil --fork-url https://forno.celo.org --chain-id 42220",
    "web:dev": "cd apps/web && bun run dev",
    "agent:dev": "cd apps/agent && bun run dev",
    "server:dev": "cd apps/server && bun run dev",
    "e2e": "cd e2e && bun run src/e2e.ts",
    "demo": "cd e2e && bun run src/demo.ts"
  }
}
